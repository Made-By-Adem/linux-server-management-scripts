# Source server (IP or hostname)
REMOTE_HOST="192.168.1.100"

# Friendly name for the backup folder (e.g. "fireman", "webserver")
REMOTE_NAME="fireman"

# SSH user on the source server (must match the user that has the key in authorized_keys)
REMOTE_USER="admin"

# SSH port (default: 22)
SSH_PORT="22"

# SSH key path - use an absolute path, not $HOME or ~
SSH_KEY="/home/your-user/.ssh/id_ed25519"

# Local directory to store the backup (default: next to this script)
# BACKUP_DEST="/home/your-user/backups"

# Telegram notifications (optional - leave empty to disable)
# TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrSTUvwxYZ"
# TELEGRAM_CHAT_ID="123456789"

# Folders to backup from the remote server (one per line)
BACKUP_FOLDERS=(
    "/etc"
    "/home"
    "/opt/docker"
    "/var/lib/docker/volumes"
)
